<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/qr_overlay">

    <!-- Camera Preview -->
    <androidx.appcompat.widget.AppCompatSurfaceView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay UI -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Bar -->
        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@drawable/scanner_top_gradient"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="56dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="@string/scan_qr"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:letterSpacing="-0.01" />

            <ImageView
                android:id="@+id/button_close_scanner"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/scanner_button_background"
                android:contentDescription="@string/close"
                android:padding="10dp"
                android:src="@drawable/ic_close"
                app:tint="@color/text_primary" />

        </LinearLayout>

        <!-- Scan Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Scan Frame -->
            <FrameLayout
                android:layout_width="280dp"
                android:layout_height="280dp">

                <!-- Corner Markers -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:src="@drawable/qr_corner_tl"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:src="@drawable/qr_corner_tr"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="8dp"
                    android:src="@drawable/qr_corner_bl"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:src="@drawable/qr_corner_br"
                    android:contentDescription="@null" />

                <!-- Scanning Line -->
                <View
                    android:id="@+id/scan_line"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="top"
                    android:background="@color/qr_scan_line" />

            </FrameLayout>

            <!-- Hint Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:paddingHorizontal="32dp"
                android:text="@string/qr_scan_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Bottom Bar -->
        <LinearLayout
            android:id="@+id/layout_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/scanner_bottom_gradient"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Flash Toggle -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_toggle_flash"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:drawablePadding="8dp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="24dp"
                android:text="@string/toggle_flash_on"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_flash_off"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/primary"
                style="@style/Widget.Material3.Button.TonalButton" />

        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
