<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/camera_overlay">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay UI -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Bar -->
        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@drawable/qr_scanner_top_background"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="@string/scan_qr"
                android:textColor="@color/text_on_dark"
                android:textSize="18sp" />

            <ImageView
                android:id="@+id/buttonClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/qr_scanner_button_background"
                android:contentDescription="@string/close"
                android:padding="10dp"
                android:src="@drawable/ic_close"
                app:tint="@color/text_on_dark" />

        </LinearLayout>

        <!-- QR Scan Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Scan Frame -->
            <FrameLayout
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:background="@drawable/qr_scan_frame">

                <!-- Corner Markers -->
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="12dp"
                    android:src="@drawable/qr_corner_top_left"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:src="@drawable/qr_corner_top_right"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="12dp"
                    android:src="@drawable/qr_corner_bottom_left"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:src="@drawable/qr_corner_bottom_right"
                    android:contentDescription="@null" />

                <!-- Scanning Line (Animated) -->
                <View
                    android:id="@+id/scan_line"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="top"
                    android:background="@color/qr_scan_line" />

            </FrameLayout>

            <!-- Hint Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:paddingHorizontal="32dp"
                android:text="@string/qr_scan_hint"
                android:textColor="@color/text_on_dark"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Bottom Bar with Flash Toggle -->
        <LinearLayout
            android:id="@+id/layout_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/qr_scanner_bottom_background"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Flash Toggle -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_toggle_flash"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:drawablePadding="8dp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:text="@string/toggle_flash_on"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_flash_off"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

        </LinearLayout>

    </FrameLayout>

    <!-- Processing Overlay -->
    <FrameLayout
        android:id="@+id/panel_processing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/camera_overlay"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="@color/primary"
            app:indicatorSize="48dp" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
