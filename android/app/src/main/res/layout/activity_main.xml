<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <LinearLayout
        android:id="@+id/panel_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp">

                <ImageView
                    android:id="@+id/image_app_logo"
                    android:layout_width="114dp"
                    android:layout_height="114dp"
                    android:layout_gravity="center_horizontal"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/v_portal2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/home_card_background"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_scan_qr"
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:background="@drawable/home_primary_button"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.01"
                        android:text="@string/scan_qr"
                        android:textAllCaps="false"
                        android:textColor="@color/home_button_text"
                        android:textSize="22sp"
                        app:backgroundTint="@null"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_open_from_file"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/home_outline_button"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.01"
                        android:text="@string/open_from_file"
                        android:textAllCaps="false"
                        android:textColor="@color/home_primary"
                        android:textSize="17sp"
                        app:backgroundTint="@null"
                        app:cornerRadius="14dp"
                        app:strokeWidth="0dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/home_card_background"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/button_try_demo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/home_secondary_row_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:orientation="horizontal"
                        android:paddingStart="13dp"
                        android:paddingEnd="11dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_qr_code_scanner"
                            app:tint="@color/home_row_icon" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="@string/try_demo"
                            android:textColor="@color/home_row_text"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/home_row_icon" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_check_ar_support"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="9dp"
                        android:background="@drawable/home_secondary_row_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:orientation="horizontal"
                        android:paddingStart="13dp"
                        android:paddingEnd="11dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_ar_status"
                            app:tint="@color/home_row_icon" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="@string/check_ar_core_label"
                            android:textColor="@color/home_row_text"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/home_row_icon" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_how_it_works"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="9dp"
                        android:background="@drawable/home_secondary_row_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:orientation="horizontal"
                        android:paddingStart="13dp"
                        android:paddingEnd="11dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_info"
                            app:tint="@color/home_row_icon" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="@string/how_it_works"
                            android:textColor="@color/home_row_text"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/home_row_icon" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_order_ar"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/home_order_button_background"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.01"
                    android:text="@string/order_ar"
                    android:textAllCaps="false"
                    android:textColor="@color/home_row_text"
                    android:textSize="18sp"
                    app:backgroundTint="@null"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_add_circle_outline"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="@color/home_row_text"
                    app:strokeWidth="0dp" />

            </LinearLayout>

        </ScrollView>

        <LinearLayout
            android:id="@+id/footer_links_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/text_support"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"
                android:text="@string/footer_support"
                android:textColor="@color/home_footer_text"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•"
                android:textColor="@color/home_footer_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_privacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"
                android:text="@string/footer_privacy"
                android:textColor="@color/home_footer_text"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•"
                android:textColor="@color/home_footer_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_about"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"
                android:text="@string/footer_about"
                android:textColor="@color/home_footer_text"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/panel_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/home_background"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="@color/home_primary"
                app:indicatorSize="56dp"
                app:trackThickness="4dp" />

            <TextView
                android:id="@+id/text_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/loading_content_short"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:id="@+id/panel_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/home_background"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_error"
                app:tint="@color/error" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="24dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/text_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"
                    android:padding="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@android:color/white"
                    tools:text="РћС€РёР±РєР° СЃРµС‚Рё. РџСЂРѕРІРµСЂСЊС‚Рµ РїРѕРґРєР»СЋС‡РµРЅРёРµ." />

            </ScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_retry"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:paddingHorizontal="32dp"
                android:text="@string/retry"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_open_device_list"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:paddingHorizontal="24dp"
                android:text="@string/button_open_device_list"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:visibility="gone"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>

