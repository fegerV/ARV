<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="60dp"
            android:paddingBottom="32dp">

            <!-- Logo & Tagline -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:gravity="center"
                android:orientation="vertical">

                <!-- App Icon -->
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="16dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_launcher" />

                <!-- App Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="32sp"
                    android:letterSpacing="-0.02" />

                <!-- Tagline -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/app_tagline"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:lineHeight="22dp" />

            </LinearLayout>

            <!-- Primary Action: Scan QR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_scan_qr"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/scan_qr"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:letterSpacing="0"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_qr_code_scanner"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="24dp"
                app:iconTint="@color/on_primary" />

            <!-- Secondary Action: Demo AR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_try_demo"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/demo_ar"
                android:textAllCaps="false"
                android:textSize="17sp"
                app:cornerRadius="16dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <!-- Divider -->
            <View
                android:layout_width="64dp"
                android:layout_height="1dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:background="@color/divider" />

            <!-- Secondary Functions (Grid) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:orientation="horizontal">

                <!-- Load from Gallery -->
                <LinearLayout
                    android:id="@+id/button_open_from_file"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/icon_button_background"
                        android:padding="12dp"
                        android:src="@drawable/ic_gallery"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/load_qr_gallery"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </LinearLayout>

                <!-- How It Works -->
                <LinearLayout
                    android:id="@+id/button_how_it_works"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/icon_button_background"
                        android:padding="12dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/how_it_works"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Check AR Support -->
                <LinearLayout
                    android:id="@+id/button_check_ar_support"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/icon_button_background"
                        android:padding="12dp"
                        android:src="@drawable/ic_ar_status"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/check_ar_support"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </LinearLayout>

            </LinearLayout>

            <!-- Manual Input Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/enter_code"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_unique_id"
                    style="@style/Widget.VPortal.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="@string/enter_code_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_unique_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_open"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/open"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:cornerRadius="16dp"
                    style="@style/Widget.Material3.Button.TonalButton" />

            </LinearLayout>

            <!-- Bottom Spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/panel_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="@color/primary"
                app:indicatorSize="48dp"
                app:trackThickness="3dp" />

            <TextView
                android:id="@+id/text_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/loading_content_short"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Error Overlay -->
    <FrameLayout
        android:id="@+id/panel_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Error Icon -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="24dp"
                android:src="@drawable/ic_error"
                android:contentDescription="@null"
                app:tint="@color/error" />

            <!-- Error Message -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="24dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/text_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"
                    android:padding="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Ошибка сети. Проверьте подключение." />

            </ScrollView>

            <!-- Retry Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_retry"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="32dp"
                android:text="@string/retry"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp" />

            <!-- Device List Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_open_device_list"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="24dp"
                android:text="@string/button_open_device_list"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:visibility="gone"
                app:cornerRadius="12dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
