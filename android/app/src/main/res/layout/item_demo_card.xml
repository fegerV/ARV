<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="244dp">

        <ImageView
            android:id="@+id/image_demo_marker"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:padding="12dp"
            android:scaleType="fitCenter"
            tools:src="@tools:sample/backgrounds/scenic" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/demo_card_image_overlay" />

        <TextView
            android:id="@+id/text_demo_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="14dp"
            android:background="@drawable/demo_badge_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Демо 1"
            android:textColor="@color/text_on_dark"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            android:background="@drawable/ar_button_background"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp">

            <ImageButton
                android:id="@+id/button_download_marker"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/icon_button_background"
                android:contentDescription="@string/demo_save_image"
                android:padding="10dp"
                android:src="@drawable/ic_download"
                android:tint="@color/primary" />

            <ImageButton
                android:id="@+id/button_share_marker"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/icon_button_background"
                android:contentDescription="@string/demo_share"
                android:padding="10dp"
                android:src="@drawable/ic_share"
                android:tint="@color/primary" />

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
