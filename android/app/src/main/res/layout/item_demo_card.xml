<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/image_demo_marker"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:adjustViewBounds="true"
            android:background="@android:color/white"
            android:contentDescription="@null"
            android:padding="10dp"
            android:scaleType="centerInside"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@tools:sample/backgrounds/scenic" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/demo_card_image_overlay"
            app:layout_constraintBottom_toBottomOf="@id/image_demo_marker"
            app:layout_constraintEnd_toEndOf="@id/image_demo_marker"
            app:layout_constraintStart_toStartOf="@id/image_demo_marker"
            app:layout_constraintTop_toTopOf="@id/image_demo_marker" />

        <TextView
            android:id="@+id/text_demo_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@drawable/demo_badge_background"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="Демо 1"
            android:textColor="@color/text_on_dark"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/image_demo_marker"
            app:layout_constraintTop_toTopOf="@id/image_demo_marker" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@drawable/ar_button_background"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp"
            app:layout_constraintBottom_toBottomOf="@id/image_demo_marker"
            app:layout_constraintEnd_toEndOf="@id/image_demo_marker">

            <ImageButton
                android:id="@+id/button_download_marker"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/icon_button_background"
                android:contentDescription="@string/demo_save_image"
                android:padding="10dp"
                android:src="@drawable/ic_download"
                android:tint="@color/primary" />

            <ImageButton
                android:id="@+id/button_share_marker"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/icon_button_background"
                android:contentDescription="@string/demo_share"
                android:padding="10dp"
                android:src="@drawable/ic_share"
                android:tint="@color/primary" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
