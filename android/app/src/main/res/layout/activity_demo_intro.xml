<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/hero_space_background">

            <View
                android:id="@+id/star_one"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="54dp"
                android:layout_marginTop="34dp"
                android:background="@drawable/star_dot" />

            <View
                android:id="@+id/star_two"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="58dp"
                android:layout_marginEnd="78dp"
                android:background="@drawable/star_dot" />

            <View
                android:id="@+id/star_three"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_gravity="center|start"
                android:layout_marginStart="36dp"
                android:background="@drawable/star_dot" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="110dp"
                android:layout_marginBottom="34dp"
                android:background="@drawable/star_dot" />

            <View
                android:layout_width="2dp"
                android:layout_height="2dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="22dp"
                android:background="@drawable/star_dot" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="118dp"
                android:layout_marginBottom="38dp"
                android:background="@drawable/star_dot" />

            <View
                android:layout_width="2dp"
                android:layout_height="2dp"
                android:layout_gravity="center|end"
                android:layout_marginEnd="126dp"
                android:background="@drawable/star_dot" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp">

                <ImageView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginBottom="14dp"
                    android:contentDescription="@string/app_name"
                    android:src="@mipmap/ic_launcher" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/demo_gallery_title"
                    android:textAlignment="center"
                    android:textColor="@color/text_on_dark"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxWidth="340dp"
                    android:text="@string/demo_gallery_subtitle"
                    android:textAlignment="center"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

        </FrameLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:id="@+id/progress_demo_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/loading_content_short"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/text_demo_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="24dp"
                    android:textColor="@color/error"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:text="Демо временно недоступны"
                    tools:visibility="visible" />

                <GridLayout
                    android:id="@+id/container_demo_cards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alignmentMode="alignMargins"
                    android:columnCount="1"
                    android:columnOrderPreserved="false"
                    android:useDefaultMargins="true"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="32dp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</FrameLayout>
