<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- V-Portal Premium Theme (Apple-style Minimalism) -->
    <style name="Theme.ArViewer" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <!-- Secondary -->
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary_variant</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        
        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Status bars -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        
        <!-- Material components -->
        <item name="materialCardViewStyle">@style/Widget.VPortal.Card</item>
        <item name="materialButtonStyle">@style/Widget.VPortal.Button</item>
    </style>
    
    <!-- AR Mode Theme (Pure Black) -->
    <style name="Theme.ArViewer.AR" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/ar_accent</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/ar_background</item>
        
        <item name="android:colorBackground">@color/ar_background</item>
        <item name="colorSurface">@color/ar_surface</item>
        <item name="colorOnSurface">@color/ar_text_primary</item>
        
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/ar_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
    
    <!-- Splash Screen -->
    <style name="Theme.ArViewer.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.ArViewer</item>
    </style>
    
    <!-- QR Scanner (Full Screen Dark) -->
    <style name="Theme.ArViewer.Scanner" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
    
    <!-- V-Portal Card (Premium) -->
    <style name="Widget.VPortal.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/card_border</item>
        <item name="contentPadding">20dp</item>
    </style>
    
    <!-- V-Portal Button (Primary - Large) -->
    <style name="Widget.VPortal.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFeatureSettings">ss03</item>
    </style>
    
    <!-- V-Portal Button (Secondary - Outlined) -->
    <style name="Widget.VPortal.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <!-- V-Portal Button (Tonal - Small) -->
    <style name="Widget.VPortal.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/surface_variant</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <!-- V-Portal Button (Text - Link Style) -->
    <style name="Widget.VPortal.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">15sp</item>
    </style>
    
    <!-- V-Portal Button (AR Mode) -->
    <style name="Widget.VPortal.Button.AR" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/ar_accent</item>
        <item name="android:textColor">@color/ar_background</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- V-Portal FAB (AR Controls) -->
    <style name="Widget.VPortal.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/ar_accent</item>
        <item name="tint">@color/ar_background</item>
        <item name="elevation">6dp</item>
    </style>
    
    <!-- V-Portal Input Field -->
    <style name="Widget.VPortal.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>
    
    <!-- Typography: Headline -->
    <style name="TextAppearance.VPortal.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:fontFeatureSettings">ss03</item>
    </style>
    
    <!-- Typography: Title -->
    <style name="TextAppearance.VPortal.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Typography: Body -->
    <style name="TextAppearance.VPortal.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">24dp</item>
    </style>
    
    <!-- Typography: Caption -->
    <style name="TextAppearance.VPortal.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- AR Typography -->
    <style name="TextAppearance.VPortal.AR.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/ar_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.VPortal.AR.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/ar_text_secondary</item>
    </style>
</resources>
